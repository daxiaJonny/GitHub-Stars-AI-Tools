{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "ignoreDeprecations": "6.0",
    "baseUrl": ".",
    "paths": {
      "@stars-ai/domain": ["packages/domain/src/index.ts"],
      "@stars-ai/storage": ["packages/storage/src/index.ts"],
      "@stars-ai/github": ["packages/github/src/index.ts"],
      "@stars-ai/ai": ["packages/ai/src/index.ts"],
      "@stars-ai/search": ["packages/search/src/index.ts"],
      "@stars-ai/worker": ["packages/worker/src/index.ts"]
    },
    "strict": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true
  }
}